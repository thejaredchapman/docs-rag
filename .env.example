# Chat + embedding models. litellm resolves the provider from the model
# name prefix (e.g. "gpt-4o", "claude-sonnet-4-6", "ollama/llama3.1").
# Change these to switch providers -- no code changes needed.
CHAT_MODEL=gpt-4o
EMBED_MODEL=text-embedding-3-small

# Provider API keys. litellm reads whichever one matches your chosen model.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: arbitrary extra params forwarded as-is into litellm.completion()
# / litellm.embedding(), as a JSON object. Use this for anything beyond
# CHAT_MODEL/EMBED_MODEL -- temperature, azure_deployment, aws_region_name,
# vertex_project, extra_headers, or even a "model" key that overrides
# CHAT_MODEL/EMBED_MODEL entirely. No schema is enforced beyond "must be a
# JSON object" -- any provider litellm supports works here.
# CHAT_PARAMS={"temperature": 0.2}
# EMBED_PARAMS={}

# Optional: point at a running LiteLLM proxy
# (`litellm --config litellm_proxy_config.example.yaml`) instead of calling
# providers directly. When set, CHAT_MODEL/EMBED_MODEL must match names
# registered in the proxy's config -- you can then swap or add backend
# models server-side without touching this app at all.
# LITELLM_API_BASE=http://localhost:4000
# LITELLM_API_KEY=sk-litellm-proxy-key

FLASK_PORT=5050
